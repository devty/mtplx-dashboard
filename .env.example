# Copy to .env and export into your shell, or pass inline:
#   MTPLX_URL=http://box.local:8000 npm run dev
# This project does not read .env automatically (no dotenv dependency) —
# keeping the dependency list minimal. Use your shell/direnv, or Node's
# native `--env-file=.env` flag if you want file-based env loading:
#   node --env-file=.env dist/server.js

# MTPLX server this process polls (server-to-server, not subject to browser CORS)
MTPLX_URL=http://127.0.0.1:8000

# Port this dashboard server listens on
PORT=8123

# How often to poll MTPLX's /metrics endpoint
POLL_INTERVAL_MS=1000

# Timeout for each poll request to MTPLX
MTPLX_TIMEOUT_MS=2500

# Depth of the server-side sparkline history ring buffers (dashboard)
RING_SIZE=120

# Depth of the server-side live-log rolling buffer
LOG_BUFFER_SIZE=300

# Ceiling for poll-retry backoff when MTPLX is unreachable
MAX_BACKOFF_MS=10000
