+def _dashboard_capture_bodies_enabled() -> bool:
+    """Opt-in switch for storing full prompt/response text on metrics records.
+
+    Off by default: full bodies are large and privacy-sensitive, and /metrics
+    is unauthenticated on localhost. Enable with MTPLX_DASHBOARD_CAPTURE_BODIES=1
+    when a trusted local dashboard wants complete per-request transcripts.
+    """
+
+    return os.environ.get("MTPLX_DASHBOARD_CAPTURE_BODIES", "").strip().lower() in {
+        "1",
+        "true",
+        "yes",
+        "on",
+    }
+
+
+def _dashboard_body_max_chars() -> int:
+    """Per-field cap for captured bodies (default 20k chars). 0 disables the cap."""
+
+    try:
+        value = int(os.environ.get("MTPLX_DASHBOARD_BODY_MAX_CHARS", "20000"))
+    except ValueError:
+        return 20000
+    return max(0, value)
+
+
+def _clip_body(text: str) -> str:
+    limit = _dashboard_body_max_chars()
+    return text if limit <= 0 else text[:limit]
+
+
+def _dashboard_capture_response_text(state: "ServerState", text: str | None) -> None:
+    """Best-effort: stamp the finished response text onto the latest record.
+
+    No-ops unless capture is enabled. Deliberately tolerant — a capture glitch
+    must never break a user-visible response — so all failures are swallowed.
+    """
+
+    if not _dashboard_capture_bodies_enabled():
+        return
+    if not getattr(state, "last_metrics", None):
+        return
+    try:
+        state.last_metrics[-1]["response_text"] = _clip_body(str(text or ""))
+    except BaseException:
+        pass
+
